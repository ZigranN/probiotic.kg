generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  firstName    String?
  lastName     String?
  phone        String?  @unique
  email        String?  @unique
  passwordHash String?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Product {
  id            String      @id @default(uuid())
  slug          String      @unique
  name          String
  category      Category
  heroTag       String?
  form          String?
  packInfo      String?
  description   String
  oldPriceKgs   Int?
  priceKgs      Int
  inStock       Boolean     @default(true)
  shortBenefits Json
  forWhom       Json?
  keyNotes      Json?
  howToUse      Json?
  cautions      Json?
  storage       Json?
  images        Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  createdAt     DateTime    @default(now())
  customerName  String
  customerPhone String
  totalPrice    Float
  status        String      @default("NEW")
  user          User?       @relation(fields: [userId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  quantity    Int
  name        String
  price       Float
  productSlug String
  order       Order   @relation(fields: [orderId], references: [id])
  product     Product @relation(fields: [productSlug], references: [slug])
}

model PartnershipLead {
  id             String   @id @default(uuid())
  name           String
  phone          String
  email          String?
  desiredPackage String?
  isProcessed    Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model Article {
  id         String   @id @default(uuid())
  slug       String   @unique
  title      String
  topic      String
  content    String
  youtubeUrl String?
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum Category {
  PROBIOTIC
  CANDLES
  ACTIVES
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}
